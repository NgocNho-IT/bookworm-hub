<%- include('../layouts/header', {title: title}) %>
<div class="container mt-4">
   <div class="row mb-4 align-items-center justify-content-between bg-body-secondary p-3 rounded ">
      <div class="col-auto">
         <div class="dropdown">
            <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-tags"></i> Danh mục
            </button>
            <ul class="dropdown-menu">
               <li><a class="dropdown-item <%= currentQuery.category === 'lap-trinh'? 'active':'' %>" 
                  href="?category=lap-trinh<%= currentQuery.q ? '&q=' + currentQuery.q : '' %><%= currentQuery.status ? '&status=' + currentQuery.status : '' %>">Lập trình</a></li>
               <li><a class="dropdown-item <%= currentQuery.category === 'tieu-thuyet'? 'active':'' %>" 
                  href="?category=tieu-thuyet<%= currentQuery.q ? '&q=' + currentQuery.q : '' %><%= currentQuery.status? '&status=' + currentQuery.status : '' %>">Tiểu thuyết</a></li>
            </ul>
         </div>
      </div>

      <div class="col-auto">
         <div class="dropdown">
            <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-bookmark-check"></i> Trạng thái
            </button>
            <ul class="dropdown-menu">
               <li><a class="dropdown-item <%= currentQuery.status === 'dang-doc'? 'active' : '' %>" 
                  href="?status=dang-doc<%= currentQuery.q ? '&q=' + currentQuery.q : '' %><%= currentQuery.category ? '&category=' + currentQuery.category : '' %>">Đang đọc</a></li>
               <li><a class="dropdown-item <%= currentQuery.status === 'da-xong'? 'active' : '' %>" 
                  href="?status=da-xong<%= currentQuery.q ? '&q=' + currentQuery.q : '' %><%= currentQuery.category ? '&category=' + currentQuery.category : '' %>">Đã xong</a></li>
               <li><a class="dropdown-item <%= currentQuery.status === 'muon-mua'? 'active' : '' %>" 
                  href="?status=muon-mua<%= currentQuery.q ? '&q=' + currentQuery.q : '' %><%= currentQuery.category ? '&category=' + currentQuery.category : '' %>">Muốn mua</a></li>
            </ul>
         </div>
      </div>

      <div class="col-5">
         <div class="container-fluid">
            <form class="d-flex" role="search">
                <% if (currentQuery.category) { %>
                  <input type="hidden" name="category" value="<%= currentQuery.category %>"/>
                <% } %>

                <% if (currentQuery.status) { %>
                  <input type="hidden" name="status" value="<%= currentQuery.status %>">
                <% } %>
               <input class="form-control me-2" type="search" placeholder="Tìm theo tên sách..." aria-label="Search" name="q" value="<%= currentQuery.q || '' %>"/>
               <button class="btn btn-outline-success" type="submit"><i class="bi bi-search"></i></button>
            </form>
         </div>
      </div>

      <div class="col-auto">
         <a href="/books" class="btn btn-dark"><i class="bi bi-funnel-fill"></i> Xóa lọc</a>
      </div>

      <div class="col-auto">
            <a href="/books/create-book" class="btn btn-success"><i class="bi bi-plus-circle"></i> Thêm sách</i></a>
      </div>

   </div>

   <table class="table table-striped align-middle border-top">
      <thead>
         <tr>
            <th scope="col">Ảnh</th>
            <th scope="col">Tên sách</th>
            <th scope="col">Tác giả</th>
            <th scope="col">Năm xuất bản</th>
            <th scope="col">Danh mục</th>
            <th scope="col">Trạng thái</th>
            <th scope="col">Hành động</th>
         </tr>
      </thead>
      <tbody>
         <% if (books && books.length > 0) { %>
            <% books.forEach(book => { %>
         <tr>
            <td><img src="<%= book.image %>" alt="Bìa sách" style="width: 60px; height: 80px; object-fit: cover; border-radius: 4px;"></td>
            <td><%= book.subject %></td>
            <td><%= book.author %></td>
            <td><%= book.publication_year %></td>
            <td><%= book.idCategory.name %></td>
            <td><%= book.idStatus.name %></td>
            <td>
               <a href="/books/update-book/<%= book._id %>" class="btn btn-primary">
                  <i class="bi bi-pencil-square"></i>
               </a>

               <form action="/books/delete-book/<%= book._id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-danger" onclick="return confirm('Nhớ có chắc muốn xóa không?')">
                     <i class="bi bi-trash-fill"></i>
                  </button>
               </form>
            </td>
         </tr>
         <% }) %>

         <% } else { %>
            <tr><td colspan="7" class="text-center py-4 text-muted">Không tìm thấy sách phù hợp với bộ lọc</td></tr>
         <% } %>
      </tbody>
   </table>

   <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
   <nav aria-label="Page navigation" class="mt-5">
      <ul class="pagination justify-content-center">
         <% 
            let qStr = '';
            // Cách viết này nó thay thế cho viết cộng chuỗi 
            // Cách viết nội suy biến ${tên_biến} thay vì dùng cộng chuỗi
            if (typeof currentQuery !== 'undefined') { 
               if (currentQuery.q) qStr += `&q=${currentQuery.q}`;
               if (currentQuery.category) qStr += `&category=${currentQuery.category}`;
               if (currentQuery.status) qStr += `&status=${currentQuery.status}`;
            }
          %>

         <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
            <a class="page-link" href="<%= currentPage <= 1 ? '#' : '?page=' + (currentPage - 1) + qStr %>">Trang trước</a>
         </li>
         <% for(let i = 1; i <= totalPages; i++) { %>
         <li class="page-item <%= currentPage == i ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= i %><%= qStr %>"><%= i %></a>
         </li>
         <% } %>
         <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="<%= currentPage >= totalPages ? '#' : '?page=' + (parseInt(currentPage) + 1) + qStr %>">Trang sau</a>
         </li>
      </ul>
   </nav>
   <% } %>

   <div class="text-center mt-5 mb-5"><a href="/" class="btn btn-success px-4 rounded-pill"><i class="bi bi-house-door me-2"></i> Quay về trang chủ</a></div>
</div>