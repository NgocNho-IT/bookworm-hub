<%- include('../layouts/header', {title: 'Create book'}) %>
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0 text-center">Thêm Sách Mới</h4>
                </div>
                <div class="card-body p-4">
                    
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div style="background-color: #f8d7da; color: #721c24; padding: 10px; margin-bottom: 15px; border-radius: 4px;">
                            <%= error %>
                        </div>
                    <% } %>

                    <form action="/books/create" method="POST">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề sách <span class="text-danger">*</span></label>
                            <input type="text" name="subject" class="form-control" placeholder="Nhập tên sách..." value="<%= formData.subject || '' %>">
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tác giả <span class="text-danger">*</span></label>
                            <input type="text" name="author" class="form-control" placeholder="Nhập tên tác giả..." value="<%= formData.author || '' %>">
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Năm xuất bản</label>
                            <input type="number" name="publication_year" class="form-control" placeholder="Ví dụ: 2023" value="<%= formData.publication_year || '' %>">
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                                <select name="idCategory" class="form-select">
                                    <option value="" disabled <%= !formData.idCategory ? 'selected' : '' %>>-- Chọn danh mục --</option>
                                    <% categories.forEach(cate => { %>
                                        <option value="<%= cate._id %>" <%= (formData.idCategory === cate._id.toString()) ? 'selected' : '' %>>
                                            <%= cate.name %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Trạng thái <span class="text-danger">*</span></label>
                                <select name="idStatus" class="form-select">
                                    <option value="" disabled <%= !formData.idStatus ? 'selected' : '' %>>-- Chọn trạng thái --</option>
                                    <% statuses.forEach(stat => { %>
                                        <option value="<%= stat._id %>" <%= (formData.idStatus === stat._id.toString()) ? 'selected' : '' %>>
                                            <%= stat.name %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Link hình ảnh</label>
                            <input type="text" name="image" class="form-control" placeholder="Nhập URL ảnh bìa sách..." value="<%= formData.image || '' %>">
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Mô tả sách</label>
                            <textarea name="description" class="form-control" rows="3" placeholder="Vài dòng tóm tắt nội dung..."><%= formData.description || '' %></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Tạo mới sách</button>
                            <a href="/books" class="btn btn-outline-secondary">Hủy bỏ</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

